{
  "name": "screenplay-studio",
  "version": "0.1.0",
  "description": "\u7535\u5f71\u3001\u77ed\u5267\u3001\u5267\u672c\u521b\u4f5c\u684c\u9762\u5e94\u7528 \u00b7 Electron + FastAPI",
  "author": "",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"wait-on http://127.0.0.1:5173 && npm run dev:electron\"",
    "backend": "cd backend && uvicorn app.main:app --reload --host 127.0.0.1 --port 18766",
    "prestart": "npm run build:renderer",
    "start": "electron .",
    "icons": "node scripts/generate-brand-icons.mjs",
    "build:renderer": "vite build --mode production",
    "build:renderer:dev": "vite build --mode development",
    "obfuscate:renderer:manual": "node scripts/obfuscate-renderer-dist.mjs",
    "dist": "npm run icons && npm run build:renderer && node ./node_modules/electron-builder/cli.js --publish never",
    "pack": "npm run icons && npm run build:renderer && node ./node_modules/electron-builder/cli.js --dir",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "javascript-obfuscator": "^4.2.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-bundle-obfuscator": "^1.12.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@types/react-router-dom": "^5.3.3",
    "hyperframes": "^0.5.6",
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0"
  },
  "build": {
    "appId": "com.screenplaystudio.app",
    "productName": "Screenplay Studio",
    "copyright": "Copyright Screenplay Studio contributors",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": [
      "build/icon.ico",
      "build/icon.png"
    ],
    "icon": "icon.png",
    "files": [
      "electron/**/*.cjs",
      "renderer/dist/**/*",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/venv/**",
          "!**/.venv/**"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  }
}
